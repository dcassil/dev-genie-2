{
  "name": "daimyo",
  "version": "0.14.0",
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.mjs"
    }
  },
  "bin": {
    "daimyo": "bin/daimyo.js",
    "daimyo-mcp": "bin/daimyo-mcp.js"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --target=node18 --outfile=dist/index.mjs && esbuild src/mcp/server-entry.ts --bundle --platform=node --format=esm --target=node18 --outfile=dist/daimyo-mcp.mjs && esbuild src/cli/main.ts --bundle --platform=node --format=esm --target=node18 --outfile=dist/daimyo-cli.mjs && tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.148",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "protocol": "file:../protocol"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@typescript-eslint/eslint-plugin": "^8.46.4",
    "@typescript-eslint/parser": "^8.46.4",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.1",
    "typescript": "^5.9.3",
    "vitest": "^1.6.0"
  }
}
