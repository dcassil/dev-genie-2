{
  "name": "protocol",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "schemas",
    "src/generated"
  ],
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --target=node18 --outfile=dist/index.mjs && tsc -p tsconfig.build.json",
    "codegen": "tsx scripts/codegen.ts",
    "check:compat": "tsx scripts/check-compatibility.ts",
    "check:codegen": "tsx scripts/check-codegen.ts",
    "validate:schemas": "tsx scripts/validate-schemas.ts",
    "test": "npm run validate:schemas && npm run check:codegen && npm run check:compat && vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@typescript-eslint/eslint-plugin": "^8.46.4",
    "@typescript-eslint/parser": "^8.46.4",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.1",
    "json-schema-to-typescript": "^15.0.4",
    "tsx": "^4.22.2",
    "typescript": "^5.9.3",
    "vitest": "^1.6.0"
  }
}
