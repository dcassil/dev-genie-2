.DS_Store

# Dependencies and builds
node_modules/
dist/
coverage/
.next/

# Plugin build artifacts MUST ship to the marketplace cache, so un-ignore
# every plugin's dist/ even though `dist/` is ignored above. Add new plugins
# here as they grow a build step.
!katana/dist/
!katana/dist/**

# Local databases and logs
*.db
*.db-shm
*.db-wal
*.log

# Local runtime state
.audit/
.katana/
.dev-genie/

# Local editor / agent settings
.claude/settings.local.json

