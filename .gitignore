.DS_Store

# Secrets / local env — never commit
.env
.env.local
.env.*.local

# Dependencies and builds
node_modules/
dist/
coverage/
.next/
.npm-cache/

# Marketplace-distributed PLUGINS commit their self-contained bundled dist/ so
# the marketplace cache can launch them with no install step; un-ignore each
# plugin's dist/. Shared LIBRARY packages (protocol, roles, engines,
# protocol-proof) are NOT distributed and are bundled into plugins at build time,
# so they do NOT commit dist/ (DGOS-T-0046). Add a plugin here when it ships.
!katana/dist/
!katana/dist/**
!daimyo/dist/
!daimyo/dist/**

# Local databases and logs
*.db
*.db-shm
*.db-wal
*.log
.metis.orig/

# Local runtime state
.audit/
.katana/
.dev-genie/

# Local editor / agent settings
.claude/settings.local.json
